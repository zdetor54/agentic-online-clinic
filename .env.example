# .env.example - Template for secrets and environment-specific configuration
# ----------------------------------------------------------------------------------
# Rule of thumb:
# - Secrets and/or values that change across dev/staging/prod → keep in `.env`
# - Logic or tunable behaviour → keep in `configs/config.yaml`
# ----------------------------------------------------------------------------------
# Rename to `.env` in your local environment
# This should match the implementation found in src/core/env.py

# App environment
GENERAL_ENV="dev"
GENERAL_DEBUG=true

# Azure OpenAI credentials
AZURE_OPENAI_API_KEY="abc123"
AZURE_OPENAI_ENDPOINT="https://in-bjss-openai-us.openai.azure.com/"
AZURE_OPENAI_API_VERSION="2024-09-01-preview"
AZURE_LOCATION="eastus"
